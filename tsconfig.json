{
  "compilerOptions": {
    "target": "ES2020",

    "module": "Node16",
    "moduleResolution": "Node16",

    "rootDir": ".",
    "outDir": "dist",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,

    "ignoreDeprecations": "6.0"
  },
  "include": ["apps/**/*", "packages/**/*"]
}